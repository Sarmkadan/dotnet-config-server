1 # ============================================================================= 2 # Author: Vladyslav Zaiets | https://sarmkadan.com 3 # CTO & Software Architect 4 # ============================================================================= 5 6 # Build stage 7 FROM mcr.microsoft.com/dotnet/sdk:10.0 AS builder 8 9 WORKDIR /src 10 11 # Copy project files 12 COPY ["dotnet-config-server.csproj", "."] 13 14 # Restore dependencies 15 RUN dotnet restore "dotnet-config-server.csproj" 16 17 # Copy source code 18 COPY . . 19 20 # Build application 21 RUN dotnet build "dotnet-config-server.csproj" -c Release -o /app/build 22 23 # Publish stage 24 FROM builder AS publish 25 26 RUN dotnet publish "dotnet-config-server.csproj" -c Release -o /app/publish 27 28 # Runtime stage 29 FROM mcr.microsoft.com/dotnet/aspnet:10.0 30 31 WORKDIR /app 32 33 # Copy published application 34 COPY --from=publish /app/publish . 35 36 # Create logs directory 37 RUN mkdir -p /app/logs 38 39 # Expose port 40 EXPOSE 8080 41 42 # Set environment 43 ENV ASPNETCORE_URLS=http://+:8080 44 45 # Health check 46 HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \ 47 CMD curl -f http://localhost:8080/health || exit 1 48 49 # Start application 50 ENTRYPOINT ["dotnet", "dotnet-config-server.dll"]